<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="DB Suite">

  <listeners>
    <listener class-name="listeners.AnnotationTransformer"/>
    <listener class-name="listeners.ExtentTestNGITestListner"/>
  </listeners>

  <test name="DB Tests">
    <groups>
      <run>
        <include name="db"/>
      </run>
    </groups>

    <classes>
      <class name="dbTests.SampleDBTest"/>
    </classes>
  </test>

</suite>
